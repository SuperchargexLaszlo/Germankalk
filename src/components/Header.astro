---
const navLinks = [
  {href:'/de/', label:'Alle Rechner'},
  {href:'/de/brutto-netto-rechner', label:'Brutto-Netto'},
  {href:'/de/bmi-rechner', label:'BMI'},
  {href:'/de/prozent-rechner', label:'Prozent'},
  {href:'/de/paypal-gebuehren-rechner', label:'PayPal'},
];
const currentPath = Astro.url.pathname;
---
<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary-700 hover:text-primary-800 shrink-0">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span>RechnerBox</span>
    </a>

    <!-- Nav links (desktop) -->
    <nav class="hidden lg:flex items-center gap-1 flex-1">
      {navLinks.map(l => (
        <a href={l.href}
           class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors whitespace-nowrap
             ${currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href))
               ? 'bg-primary-100 text-primary-700'
               : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}`}>
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Region switcher -->
    <div class="flex items-center gap-1 shrink-0">
      <a href="/de/" class={`text-xs px-2.5 py-1 rounded-lg border font-medium transition ${currentPath.startsWith('/de') ? 'bg-primary-600 text-white border-primary-600' : 'border-gray-200 text-gray-500 hover:bg-gray-50'}`}>DE</a>
      <a href="/at/" class={`text-xs px-2.5 py-1 rounded-lg border font-medium transition ${currentPath.startsWith('/at') ? 'bg-primary-600 text-white border-primary-600' : 'border-gray-200 text-gray-500 hover:bg-gray-50'}`}>AT</a>
      <a href="/ch/" class={`text-xs px-2.5 py-1 rounded-lg border font-medium transition ${currentPath.startsWith('/ch') ? 'bg-primary-600 text-white border-primary-600' : 'border-gray-200 text-gray-500 hover:bg-gray-50'}`}>CH</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition" id="nav-toggle" aria-label="Menü">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="lg:hidden hidden bg-white border-t border-gray-100 px-4 py-3" id="nav-mobile">
    <div class="grid grid-cols-2 gap-1.5">
      {navLinks.map(l => (
        <a href={l.href} class="px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100 transition">{l.label}</a>
      ))}
      <a href="/at/" class="px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100 transition">🇦🇹 Österreich</a>
      <a href="/ch/" class="px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100 transition">🇨🇭 Schweiz</a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
