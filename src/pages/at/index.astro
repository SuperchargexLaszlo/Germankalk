---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const calcs = [
  {href:'/at/brutto-netto-rechner',icon:'💰',title:'Brutto-Netto Rechner',desc:'Österreichisches Nettogehalt 2026 berechnen'},
  {href:'/at/pendlerpauschale-rechner',icon:'🚗',title:'Pendlerpauschale',desc:'Österreichische Pendlerpauschale 2026'},
  {href:'/at/einkommensteuer-rechner',icon:'📊',title:'Einkommensteuer AT',desc:'Österr. Einkommensteuer & Effektivsatz berechnen'},
  {href:'/de/bmi-rechner',icon:'⚖️',title:'BMI Rechner',desc:'Body-Mass-Index nach WHO berechnen'},
  {href:'/de/kalorien-rechner',icon:'🍎',title:'Kalorienrechner',desc:'Täglichen Kalorienbedarf berechnen'},
  {href:'/de/ssw-rechner',icon:'🤰',title:'SSW Rechner',desc:'Schwangerschaftswoche berechnen'},
];
---
<BaseLayout
  title="Online Rechner Österreich 2026 – Steuer & Gehalt berechnen"
  description="Kostenlose Rechner für Österreich 2026: Brutto-Netto, Einkommensteuer, Pendlerpauschale und mehr. Mit österreichischen Steuer- und SV-Sätzen 2026."
  canonical="https://rechnerbox.eu/at/"
  hreflangAT="/at/"
>
  <Header slot="header" />
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="text-center mb-8">
      <h1>🇦🇹 Online Rechner Österreich 2026</h1>
      <p class="text-gray-500">Rechner speziell für Österreich – mit österreichischen Steuersätzen, SV-Beiträgen und Absetzbeträgen 2026.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {calcs.map(c => (
        <a href={c.href} class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-primary-200 p-5 transition-all flex items-start gap-3">
          <span class="text-2xl">{c.icon}</span>
          <div>
            <h2 class="font-semibold text-gray-900 group-hover:text-primary-700 text-base mb-1 leading-tight">{c.title}</h2>
            <p class="text-sm text-gray-500">{c.desc}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8 p-4 bg-green-50 rounded-2xl border border-green-100 text-sm text-green-800">
      <strong>AT vs. DE:</strong> Österreich hat kein Steuerklassensystem. Stattdessen gibt es Absetzbeträge (AVAB 1.684 €, Verkehrsabsetzbetrag 463 €). SV-Beiträge: 18,82% AN-Anteil 2026.
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
