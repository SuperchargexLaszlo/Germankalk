---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Kalorienrechner 2026 – Kalorienbedarf berechnen" description="Täglichen Kalorienbedarf berechnen nach Alter, Gewicht, Größe und Aktivität. Harris-Benedict-Formel. Kostenloser Kalorienrechner 2026." canonical="https://rechnerbox.eu/de/kalorien-rechner" hreflangDE="/de/kalorien-rechner">
  <Header slot="header" />
  <article class="max-w-3xl mx-auto px-4 py-8">
    <nav class="text-xs text-gray-400 mb-4"><a href="/" class="hover:text-primary-600">Startseite</a> › <a href="/de/" class="hover:text-primary-600">Deutschland</a> › Kalorienrechner</nav>
    <h1>Kalorienrechner 2026 – Tagesbedarf berechnen</h1>
    <p class="text-lg text-gray-600 mb-6">Berechnen Sie Ihren täglichen Kalorienbedarf nach der Harris-Benedict-Formel – für Ihr Gewichtziel.</p>
    <div class="calc-box">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
        <div><label class="calc-label">Alter</label><input class="calc-input" type="number" id="k-age" value="30" min="15" max="80"/></div>
        <div><label class="calc-label">Größe (cm)</label><input class="calc-input" type="number" id="k-h" value="175"/></div>
        <div><label class="calc-label">Gewicht (kg)</label><input class="calc-input" type="number" id="k-w" value="70" step="0.1"/></div>
        <div><label class="calc-label">Geschlecht</label>
          <select class="calc-select" id="k-sex"><option value="m">Männlich</option><option value="f">Weiblich</option></select>
        </div>
      </div>
      <div class="mb-4"><label class="calc-label">Aktivitätslevel</label>
        <select class="calc-select" id="k-act">
          <option value="1.2">Kaum Bewegung (Schreibtischarbeit)</option>
          <option value="1.375">Leicht aktiv (1-2x Sport/Woche)</option>
          <option value="1.55" selected>Mäßig aktiv (3-5x Sport/Woche)</option>
          <option value="1.725">Sehr aktiv (täglich Sport)</option>
          <option value="1.9">Extrem aktiv (2x täglich Training)</option>
        </select>
      </div>
      <button class="calc-btn" onclick="calcKal()">Kalorienbedarf berechnen</button>
      <div class="calc-result hidden" id="k-result">
        <div class="grid grid-cols-3 gap-3 text-center">
          <div><div class="result-value" id="k-maintain">–</div><div class="result-label">Halten (kcal)</div></div>
          <div><div class="result-value text-orange-500" id="k-lose">–</div><div class="result-label">Abnehmen (kcal)</div></div>
          <div><div class="result-value text-green-600" id="k-gain">–</div><div class="result-label">Zunehmen (kcal)</div></div>
        </div>
        <p class="text-xs text-gray-500 mt-3 text-center">Grundumsatz: <span id="k-bmr">–</span> kcal/Tag</p>
      </div>
    </div>
    <div class="info-box mt-4">💡 Tipp: Um 0,5 kg pro Woche abzunehmen, essen Sie ca. 500 kcal täglich weniger als Ihr Erhaltungsbedarf.</div>
    <section class="mt-6"><h2>FAQ – Kalorienbedarf</h2><div class="space-y-3">
      <div class="faq-item"><div class="faq-q">Wie viele Kalorien brauche ich täglich?</div><div class="faq-a">Der durchschnittliche Bedarf liegt bei Frauen bei ca. 1.800–2.000 kcal und bei Männern bei ca. 2.200–2.500 kcal. Das hängt stark von Alter, Gewicht und Aktivität ab.</div></div>
      <div class="faq-item"><div class="faq-q">Was ist der Grundumsatz?</div><div class="faq-a">Der Grundumsatz ist die Energie, die Ihr Körper im Ruhezustand verbraucht – für Atmung, Herzschlag und Organe. Er macht 60-70% des Gesamtbedarfs aus.</div></div>
    </div></section>
  </article>
  <script>
    (window as any).calcKal=function(){
      const age=parseFloat((document.getElementById('k-age') as HTMLInputElement).value);
      const h=parseFloat((document.getElementById('k-h') as HTMLInputElement).value);
      const w=parseFloat((document.getElementById('k-w') as HTMLInputElement).value);
      const sex=(document.getElementById('k-sex') as HTMLSelectElement).value;
      const act=parseFloat((document.getElementById('k-act') as HTMLSelectElement).value);
      let bmr=sex==='m'?88.36+13.4*w+4.8*h-5.7*age:447.6+9.25*w+3.1*h-4.33*age;
      const total=Math.round(bmr*act);
      const r=document.getElementById('k-result')!;r.classList.remove('hidden');
      document.getElementById('k-maintain')!.textContent=total.toLocaleString('de-DE');
      document.getElementById('k-lose')!.textContent=(total-500).toLocaleString('de-DE');
      document.getElementById('k-gain')!.textContent=(total+300).toLocaleString('de-DE');
      document.getElementById('k-bmr')!.textContent=Math.round(bmr).toLocaleString('de-DE');
    };
  </script>
  <Footer slot="footer" />
</BaseLayout>
