---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const categories = [
  { title:'💰 Gehalt & Lohn', calcs:[
    {href:'/de/brutto-netto-rechner',icon:'💶',title:'Brutto-Netto Rechner',desc:'Nettogehalt 2026 mit Steuerklasse'},
    {href:'/de/stundenlohn-rechner',icon:'⏰',title:'Stundenlohn Rechner',desc:'Monatsgehalt ↔ Stundenlohn'},
    {href:'/de/tvoed-rechner',icon:'🏢',title:'TVöD Rechner',desc:'Öffentlicher Dienst Bund & VKA'},
    {href:'/de/tv-l-rechner',icon:'🏫',title:'TV-L Rechner',desc:'Tarifvertrag Länder 2026'},
    {href:'/de/minijob-rechner',icon:'📋',title:'Minijob Rechner',desc:'Grenze 556 €/Mo – Verdienst & Abgaben'},
    {href:'/de/urlaubsgeld-rechner',icon:'🌴',title:'Urlaubsgeld Rechner',desc:'Urlaubsgeld brutto/netto'},
    {href:'/de/krankengeld-rechner',icon:'🏥',title:'Krankengeld Rechner',desc:'Krankengeld ab dem 43. Tag'},
    {href:'/de/elterngeld-rechner',icon:'👶',title:'Elterngeld Rechner',desc:'Basis + ElterngeldPlus 2026'},
    {href:'/de/rente-rechner',icon:'🏦',title:'Rente Rechner',desc:'Gesetzliche Rente · Rentenwert 40,39 €'},
    {href:'/de/industrieminuten-rechner',icon:'⏱️',title:'Industrieminuten',desc:'Dezimalzeit für Lohnabrechnung'},
  ]},
  { title:'🧾 Steuern & Abgaben', calcs:[
    {href:'/de/mwst-rechner',icon:'🧾',title:'MwSt Rechner',desc:'Mehrwertsteuer 19%/7% Netto ↔ Brutto'},
    {href:'/de/paypal-gebuehren-rechner',icon:'💳',title:'PayPal Gebühren',desc:'Exakte Gebühren sofort berechnen'},
    {href:'/de/buergergeld-rechner',icon:'🏛️',title:'Bürgergeld 2026',desc:'Anspruch – Regelsatz 563 €/Mo'},
  ]},
  { title:'🏃 Gesundheit & Fitness', calcs:[
    {href:'/de/bmi-rechner',icon:'⚖️',title:'BMI Rechner',desc:'Body-Mass-Index nach WHO'},
    {href:'/de/kalorien-rechner',icon:'🍎',title:'Kalorienrechner',desc:'Tagesbedarf Harris-Benedict'},
    {href:'/de/idealgewicht-rechner',icon:'🎯',title:'Idealgewicht Rechner',desc:'Broca, BMI, Hamwi im Vergleich'},
    {href:'/de/vitamin-d-rechner',icon:'☀️',title:'Vitamin D Rechner',desc:'IE ↔ µg, Bedarf & Spiegel'},
    {href:'/de/promille-rechner',icon:'🍺',title:'Promille Rechner',desc:'Blutalkohol Widmark-Formel'},
    {href:'/de/pace-rechner',icon:'🏃',title:'Pace Rechner',desc:'Lauftempo & Finishzeit'},
    {href:'/de/ssw-rechner',icon:'🤰',title:'SSW Rechner',desc:'Schwangerschaftswoche'},
  ]},
  { title:'📐 Mathematik & Geometrie', calcs:[
    {href:'/de/prozent-rechner',icon:'📐',title:'Prozentrechner',desc:'Prozent, Grundwert, Prozentsatz'},
    {href:'/de/dreisatz-rechner',icon:'✖️',title:'Dreisatz Rechner',desc:'Direkt & indirekt mit Lösungsweg'},
    {href:'/de/pythagoras-rechner',icon:'📏',title:'Pythagoras Rechner',desc:'a² + b² = c² berechnen'},
    {href:'/de/flaeche-rechner',icon:'⬜',title:'Flächenrechner',desc:'Kreis, Rechteck, Dreieck, Trapez'},
  ]},
  { title:'🔄 Umrechner', calcs:[
    {href:'/de/umrechnung-cm-inch',icon:'📏',title:'cm ↔ Inch Rechner',desc:'Zentimeter, Zoll, Fuß, Yard'},
    {href:'/de/kg-lbs-rechner',icon:'⚖️',title:'kg ↔ lbs Rechner',desc:'Kilogramm, Pfund, Unzen'},
    {href:'/de/celsius-fahrenheit',icon:'🌡️',title:'°C ↔ °F Rechner',desc:'Celsius, Fahrenheit, Kelvin'},
  ]},
  { title:'⏱️ Zeit & Arbeit', calcs:[
    {href:'/de/arbeitszeit-rechner',icon:'⏱️',title:'Arbeitszeitrechner',desc:'Arbeitszeit & Überstunden'},
  ]},
  { title:'🏗️ Bau & Energie', calcs:[
    {href:'/de/hoai-rechner',icon:'🏗️',title:'HOAI Rechner',desc:'Architektenhonorar HOAI 2021'},
    {href:'/de/u-wert-rechner',icon:'🏠',title:'U-Wert Rechner',desc:'Wärmedurchgangskoeffizient GEG'},
  ]},
  { title:'🚗 Auto & Finanzen', calcs:[
    {href:'/de/sprit-rechner',icon:'⛽',title:'Spritrechner',desc:'Kraftstoffverbrauch & Kosten'},
    {href:'/de/goldpreis-rechner',icon:'🥇',title:'Goldpreis Rechner',desc:'585/750/999er Gold bewerten'},
  ]},
];
const totalCalcs = categories.reduce((s,c)=>s+c.calcs.length,0);
const schema = {"@context":"https://schema.org","@type":"ItemList","name":"Online Rechner Deutschland 2026",
  "itemListElement":categories.flatMap(c=>c.calcs).map((c,i)=>({"@type":"ListItem","position":i+1,"url":`https://rechnerbox.eu${c.href}`,"name":c.title}))};
---
<BaseLayout
  title={`Online Rechner Deutschland 2026 – Alle ${totalCalcs} Rechner kostenlos`}
  description={`${totalCalcs} kostenlose Online-Rechner für Deutschland 2026: Brutto-Netto, TVöD, Promille, Sprit, Gold, BMI, Stundenlohn, U-Wert und viele mehr.`}
  canonical="https://rechnerbox.eu/de/"
  schema={schema}
>
  <Header slot="header" />
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="text-center mb-8">
      <h1>🇩🇪 Online Rechner Deutschland 2026</h1>
      <p class="text-gray-500 max-w-xl mx-auto">Alle {totalCalcs} Rechner – kostenlos, ohne Anmeldung, aktuell 2026.</p>
    </div>
    {categories.map(cat => (
      <div class="mb-8">
        <h2 class="text-lg font-bold text-gray-800 mb-3 pb-1.5 border-b border-gray-200">{cat.title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {cat.calcs.map(c => (
            <a href={c.href} class="group bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-primary-200 p-4 transition-all flex items-start gap-2.5">
              <span class="text-xl mt-0.5">{c.icon}</span>
              <div>
                <div class="font-semibold text-gray-900 group-hover:text-primary-700 text-sm mb-0.5 leading-tight">{c.title}</div>
                <p class="text-xs text-gray-500">{c.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
    <div class="mt-6 flex gap-4 justify-center">
      <a href="/at/" class="text-sm px-4 py-2 bg-white border border-gray-200 rounded-xl hover:border-primary-300 text-gray-600 shadow-sm">🇦🇹 Österreich</a>
      <a href="/ch/" class="text-sm px-4 py-2 bg-white border border-gray-200 rounded-xl hover:border-primary-300 text-gray-600 shadow-sm">🇨🇭 Schweiz</a>
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
