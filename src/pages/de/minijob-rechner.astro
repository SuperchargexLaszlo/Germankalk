---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CalcHero from '../../components/CalcHero.astro';
const schema = {
  "@context":"https://schema.org","@graph":[
  {"@type":"WebApplication","name":"Minijob Rechner 2026","url":"https://rechnerbox.eu/de/minijob-rechner","applicationCategory":"FinanceApplication","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"}},
  {"@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"Wie viel darf ich im Minijob 2026 verdienen?","acceptedAnswer":{"@type":"Answer","text":"Die Minijob-Grenze 2026 liegt bei 556 € pro Monat."}},
    {"@type":"Question","name":"Was zahlt der Arbeitgeber beim Minijob?","acceptedAnswer":{"@type":"Answer","text":"Der Arbeitgeber zahlt beim gewerblichen Minijob pauschal ca. 31,3% auf das Minijob-Entgelt."}},
  ]}
]};
---
<BaseLayout
  title="Minijob Rechner 2026 – Verdienst, Stunden & Abgaben berechnen"
  description="Minijob 2026 berechnen: Verdienst, Arbeitsstunden, Arbeitgeber-Abgaben und Midijob-Grenze. Minijob-Grenze 556 €/Monat."
  canonical="https://rechnerbox.eu/de/minijob-rechner"
  hreflangDE="/de/minijob-rechner"
  schema={schema}
>
  <Header slot="header" />
  <CalcHero
    title="MinijobRechner"
    subtitle="Verdienst, Arbeitsstunden & AG-Abgaben sofort berechnen"
    breadcrumbLabel="Minijob Rechner"
    country="Deutschland"
    countryHref="/de/"
  />


  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@500&display=swap" rel="stylesheet" />

  <div class="mj-page">

    <!-- ═══ HERO ═══ -->
    <div class="mj-hero">
      <div class="mj-hero-glow"></div>
      <div class="mj-hero-grid"></div>
      <div class="mj-hero-inner">
        <nav class="mj-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Startseite</a><span aria-hidden="true">›</span>
          <a href="/de/">Deutschland</a><span aria-hidden="true">›</span>
          <span>Minijob Rechner</span>
        </nav>

        <div class="mj-hero-text">
          <div class="mj-hero-tag">Aktuell 2026</div>
          <h1 class="mj-h1">Minijob<br><span class="mj-h1-accent">Rechner</span></h1>
          <p class="mj-subtitle">Verdienst, Arbeitsstunden & AG-Abgaben sofort berechnen</p>
        </div>

        <div class="mj-kpi-row">
          <div class="mj-kpi">
            <div class="mj-kpi-icon">💶</div>
            <div class="mj-kpi-val">556 €</div>
            <div class="mj-kpi-lbl">Grenze / Monat</div>
          </div>
          <div class="mj-kpi-divider"></div>
          <div class="mj-kpi">
            <div class="mj-kpi-icon">⏱</div>
            <div class="mj-kpi-val">43,4 h</div>
            <div class="mj-kpi-lbl">Max. bei 12,82 €/h</div>
          </div>
          <div class="mj-kpi-divider"></div>
          <div class="mj-kpi">
            <div class="mj-kpi-icon">🏢</div>
            <div class="mj-kpi-val">31,3 %</div>
            <div class="mj-kpi-lbl">AG-Abgaben</div>
          </div>
          <div class="mj-kpi-divider"></div>
          <div class="mj-kpi">
            <div class="mj-kpi-icon">📋</div>
            <div class="mj-kpi-val">12,82 €</div>
            <div class="mj-kpi-lbl">Mindestlohn</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ MAIN CONTENT ═══ -->
    <div class="mj-content">

      <!-- CALCULATOR CARD -->
      <div class="mj-card mj-calc-card">
        <div class="mj-card-label">RECHNER</div>

        <!-- Tabs -->
        <div class="mj-tabs" role="tablist">
          <button onclick="setMJMode('stunden')" id="mjtab-stunden"
            class="mj-tab mj-tab--active" role="tab" aria-selected="true">
            <span class="mj-tab-ico" aria-hidden="true">🕐</span>
            <span>Stunden → Verdienst</span>
          </button>
          <button onclick="setMJMode('verdienst')" id="mjtab-verdienst"
            class="mj-tab" role="tab" aria-selected="false">
            <span class="mj-tab-ico" aria-hidden="true">💰</span>
            <span>Verdienst → Stunden</span>
          </button>
          <button onclick="setMJMode('ag-kosten')" id="mjtab-ag-kosten"
            class="mj-tab" role="tab" aria-selected="false">
            <span class="mj-tab-ico" aria-hidden="true">🏢</span>
            <span>AG-Gesamtkosten</span>
          </button>
        </div>

        <!-- Panel: Stunden → Verdienst -->
        <div id="mj-stunden" class="mj-panel" role="tabpanel">
          <div class="mj-fields">
            <div class="mj-field">
              <label class="mj-label" for="mj-h">Stunden pro Monat</label>
              <div class="mj-input-wrap">
                <span class="mj-unit">h</span>
                <input class="mj-input" type="number" id="mj-h"
                  value="40" min="1" max="50" step="0.5" autocomplete="off" />
              </div>
            </div>
            <div class="mj-field">
              <label class="mj-label" for="mj-lohn">Stundenlohn</label>
              <div class="mj-input-wrap">
                <span class="mj-unit">€</span>
                <input class="mj-input" type="number" id="mj-lohn"
                  value="13.00" min="12.82" step="0.01" autocomplete="off" />
              </div>
              <p class="mj-hint">Mindestlohn 2026: 12,82 €/h</p>
            </div>
          </div>
        </div>

        <!-- Panel: Verdienst → Stunden -->
        <div id="mj-verdienst" class="mj-panel mj-panel--hidden" role="tabpanel">
          <div class="mj-fields">
            <div class="mj-field">
              <label class="mj-label" for="mj-v">Monatsverdienst</label>
              <div class="mj-input-wrap">
                <span class="mj-unit">€</span>
                <input class="mj-input" type="number" id="mj-v"
                  value="500" min="0" max="556" autocomplete="off" />
              </div>
            </div>
            <div class="mj-field">
              <label class="mj-label" for="mj-v-lohn">Stundenlohn</label>
              <div class="mj-input-wrap">
                <span class="mj-unit">€</span>
                <input class="mj-input" type="number" id="mj-v-lohn"
                  value="13.00" min="12.82" step="0.01" autocomplete="off" />
              </div>
            </div>
          </div>
        </div>

        <!-- Panel: AG-Kosten -->
        <div id="mj-ag-kosten" class="mj-panel mj-panel--hidden" role="tabpanel">
          <div class="mj-fields mj-fields--single">
            <div class="mj-field">
              <label class="mj-label" for="mj-ag-v">Monatsverdienst Minijobber</label>
              <div class="mj-input-wrap">
                <span class="mj-unit">€</span>
                <input class="mj-input" type="number" id="mj-ag-v"
                  value="500" min="0" max="556" autocomplete="off" />
              </div>
              <p class="mj-hint">Max. 556 € für Minijob · Über 556 € = Midijob / Sozialversicherungspflicht</p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <button class="mj-btn" onclick="calcMJ()" type="button">
          <span>Jetzt berechnen</span>
          <svg class="mj-btn-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>

        <!-- Results -->
        <div class="mj-result mj-result--hidden" id="mj-result" aria-live="polite">
          <div class="mj-result-top">
            <span class="mj-result-heading">Ergebnis</span>
            <span class="mj-status" id="mj-status"></span>
          </div>
          <div class="mj-res-grid" id="mj-res-grid"></div>
          <p class="mj-res-note" id="mj-res-note"></p>
        </div>
      </div>

      <!-- INFO BOX -->
      <div class="mj-infobox">
        <div class="mj-infobox-icon" aria-hidden="true">📌</div>
        <div class="mj-infobox-text">
          <strong>Arbeitgeber-Abgaben Minijob 2026:</strong>
          KV 13 % + RV 13 % + Pauschsteuer 2 % + UV ca. 1,6 % + Umlage U1/U2/Insolvenzgeld ca. 1,7 %
          = ca. <strong>31,3 %</strong> auf den Verdienst.
        </div>
      </div>

      <!-- COMPARISON TABLE -->
      <section class="mj-section">
        <h2 class="mj-h2">Minijob vs. Midijob vs. Normalbeschäftigung</h2>
        <div class="mj-table-wrap">
          <table class="mj-table">
            <thead>
              <tr>
                <th>Art</th>
                <th>Verdienstgrenze</th>
                <th>AN-Beiträge</th>
                <th>Lohnsteuer</th>
              </tr>
            </thead>
            <tbody>
              <tr class="mj-tr--hl">
                <td><span class="mj-pill mj-pill--green">Minijob</span></td>
                <td>bis 556 €/Mo</td>
                <td>nur opt. RV 3,6 %</td>
                <td>pauschal 2 % (AG)</td>
              </tr>
              <tr>
                <td><span class="mj-pill mj-pill--amber">Midijob (Gleitzone)</span></td>
                <td>556 – 2.000 €/Mo</td>
                <td>reduziert</td>
                <td>normal</td>
              </tr>
              <tr>
                <td><span class="mj-pill mj-pill--gray">Normalbeschäftigung</span></td>
                <td>ab 2.001 €/Mo</td>
                <td>volle SV-Beiträge</td>
                <td>normal</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mj-section">
        <h2 class="mj-h2">Häufige Fragen – Minijob 2026</h2>
        <div class="mj-faq-list">
          {[
            {q:"Wie viele Stunden darf ich im Minijob arbeiten?",a:"Im Minijob 2026 gibt es keine gesetzlich festgelegte maximale Stundenzahl. Entscheidend ist der Verdienst: max. 556 €/Monat. Bei Mindestlohn (12,82 €/h) sind das ca. 43 Stunden monatlich."},
            {q:"Darf ich mehrere Minijobs gleichzeitig haben?",a:"Ja, allerdings werden mehrere Minijob-Verdienste zusammengerechnet. Überschreiten sie zusammen 556 €/Monat, wird der Zweitjob sozialversicherungspflichtig. Ausnahme: Ein Minijob neben einem Hauptberuf."},
            {q:"Bekomme ich Urlaub als Minijobber?",a:"Ja. Minijobber haben denselben gesetzlichen Urlaubsanspruch wie Vollzeitbeschäftigte (24 Werktage bei 6-Tage-Woche), anteilig berechnet auf ihre Arbeitstage pro Woche."},
            {q:"Kann ich mich von der Rentenversicherungspflicht befreien lassen?",a:"Minijobber zahlen optional 3,6 % RV-Eigenanteil (= voller RV-Schutz). Sie können sich befreien lassen – verlieren dann aber die Rentenansprüche. Ein Antrag auf Befreiung ist beim Arbeitgeber zu stellen."},
          ].map((f, i) => (
            <div class="mj-faq-item" id={`faq-${i}`}>
              <button class="mj-faq-q" onclick={`toggleFaq(${i})`} aria-expanded="false" aria-controls={`faq-a-${i}`}>
                <span>{f.q}</span>
                <svg class="mj-faq-chev" id={`faq-chev-${i}`} xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="mj-faq-a" id={`faq-a-${i}`} role="region">{f.a}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- RELATED -->
      <section class="mj-section">
        <h2 class="mj-h2">Weitere Rechner</h2>
        <div class="mj-related">
          {[
            {href:'/de/brutto-netto-rechner',label:'Brutto-Netto Rechner',icon:'💼'},
            {href:'/de/stundenlohn-rechner',label:'Stundenlohn Rechner',icon:'⏰'},
            {href:'/de/arbeitszeit-rechner',label:'Arbeitszeitrechner',icon:'📅'},
            {href:'/de/urlaubsgeld-rechner',label:'Urlaubsgeld Rechner',icon:'🏖'},
            {href:'/de/krankengeld-rechner',label:'Krankengeld Rechner',icon:'🏥'},
            {href:'/de/buergergeld-rechner',label:'Bürgergeld Rechner',icon:'📋'},
          ].map(r => (
            <a href={r.href} class="mj-rel-card">
              <span class="mj-rel-ico" aria-hidden="true">{r.icon}</span>
              <span class="mj-rel-lbl">{r.label}</span>
              <svg class="mj-rel-arr" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </section>

    </div><!-- /mj-content -->
  </div><!-- /mj-page -->


  <!-- ═══ SCRIPT ═══ -->
  <script>
    let mjMode = 'stunden';
    const MINDESTLOHN = 12.82, MJ_GRENZE = 556;

    function fmt(n: number, dec = 2) {
      return n.toFixed(dec).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }
    function fmtE(n: number) { return fmt(n) + ' €'; }

    (window as any).setMJMode = function (m: string) {
      mjMode = m;
      ['stunden', 'verdienst', 'ag-kosten'].forEach(x => {
        const panel = document.getElementById('mj-' + x);
        if (panel) panel.classList.toggle('mj-panel--hidden', x !== m);
        const tab = document.getElementById('mjtab-' + x);
        if (tab) {
          tab.classList.toggle('mj-tab--active', x === m);
          tab.setAttribute('aria-selected', x === m ? 'true' : 'false');
        }
      });
      const res = document.getElementById('mj-result');
      if (res) res.classList.add('mj-result--hidden');
    };

    function showRes(items: { v: string; l: string; sub?: string }[], note = '', status = '') {
      const grid = document.getElementById('mj-res-grid')!;
      grid.innerHTML = items.map(i =>
        `<div class="mj-res-card">
          <div class="mj-res-val">${i.v}</div>
          <div class="mj-res-lbl">${i.l}</div>
          ${i.sub ? `<div class="mj-res-sub">${i.sub}</div>` : ''}
        </div>`
      ).join('');

      const badge = document.getElementById('mj-status')!;
      badge.textContent = status;
      badge.className = 'mj-status ' + (
        status.includes('Minijob') ? 'mj-status--ok' :
        status.includes('Midijob') ? 'mj-status--warn' : 'mj-status--err'
      );

      const noteEl = document.getElementById('mj-res-note')!;
      noteEl.textContent = note;

      const res = document.getElementById('mj-result')!;
      res.classList.remove('mj-result--hidden');
      res.classList.add('mj-result--pop');
      setTimeout(() => res.classList.remove('mj-result--pop'), 400);
    }

    (window as any).calcMJ = function () {
      if (mjMode === 'stunden') {
        const h = parseFloat((document.getElementById('mj-h') as HTMLInputElement).value) || 0;
        const lohn = parseFloat((document.getElementById('mj-lohn') as HTMLInputElement).value) || MINDESTLOHN;
        const v = h * lohn;
        const status = v <= MJ_GRENZE ? '✅ Minijob' : v <= 2000 ? '⚡ Midijob' : '❌ Über Grenze';
        showRes([
          { v: fmtE(v), l: 'Verdienst/Monat', sub: 'Brutto' },
          { v: fmtE(v * 0.964), l: 'Netto (ohne opt. RV)', sub: 'zum Mitnehmen' },
          { v: fmtE(v * 0.313), l: 'AG-Abgaben', sub: '31,3 % Pauschale' },
          { v: fmtE(v * 1.313), l: 'AG-Gesamtkosten', sub: 'inkl. Abgaben' },
        ], `Max. Stunden bei ${fmt(lohn)} €/h: ${fmt(MJ_GRENZE / lohn, 1)} h/Monat`, status);

      } else if (mjMode === 'verdienst') {
        const v = parseFloat((document.getElementById('mj-v') as HTMLInputElement).value) || 0;
        const lohn = parseFloat((document.getElementById('mj-v-lohn') as HTMLInputElement).value) || MINDESTLOHN;
        showRes([
          { v: fmt(v / lohn, 1) + ' h', l: 'Stunden/Monat', sub: 'bei ' + fmt(lohn) + ' €/h' },
          { v: fmtE(v), l: 'Brutto = Netto', sub: '* ohne opt. RV' },
          { v: fmtE(Math.max(0, MJ_GRENZE - v)), l: 'Puffer bis Grenze', sub: 'bis 556 €' },
          { v: fmtE(v * 0.313), l: 'AG-Abgaben', sub: '31,3 %' },
        ], '* Bei Befreiung von der optionalen Rentenversicherung',
          v <= MJ_GRENZE ? '✅ Minijob' : '⚡ Midijob');

      } else {
        const v = parseFloat((document.getElementById('mj-ag-v') as HTMLInputElement).value) || 0;
        const kv = v * .13, rv = v * .13, st = v * .02, uv = v * .016, uml = v * .017;
        showRes([
          { v: fmtE(v), l: 'AN-Verdienst', sub: 'Netto für AN' },
          { v: fmtE(kv + rv), l: 'KV + RV', sub: '13 % + 13 %' },
          { v: fmtE(st + uv + uml), l: 'Steuer + UV + Umlagen', sub: '2 % + 1,6 % + 1,7 %' },
          { v: fmtE(v + kv + rv + st + uv + uml), l: 'AG-Gesamtkosten', sub: 'total / Monat' },
        ], 'KV 13 % + RV 13 % + Pauschalsteuer 2 % + UV 1,6 % + Umlagen 1,7 %',
          v <= MJ_GRENZE ? '✅ Minijob' : '❌ Über Grenze');
      }
    };

    (window as any).toggleFaq = function (i: number) {
      const a = document.getElementById('faq-a-' + i)!;
      const btn = document.querySelector(`#faq-${i} .mj-faq-q`) as HTMLElement;
      const chev = document.getElementById('faq-chev-' + i)!;
      const open = !a.classList.contains('mj-faq-a--open');
      a.classList.toggle('mj-faq-a--open', open);
      chev.classList.toggle('mj-faq-chev--open', open);
      if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    document.addEventListener('DOMContentLoaded', () => (window as any).calcMJ());
  </script>


  <!-- ═══ STYLES ═══ -->
  <style is:global>
    /* ─── Base ─────────────────────────────────── */
    .mj-page, .mj-page * {
      font-family: 'DM Sans', system-ui, sans-serif;
      box-sizing: border-box;
    }
    .mj-page { background: #f0f4fa; min-height: 100vh; }

    /* ─── HERO ──────────────────────────────────── */
    .mj-hero {
      position: relative;
      background: #05101f;
      padding: 3.5rem 1.5rem 3rem;
      overflow: hidden;
    }
    .mj-hero-glow {
      position: absolute; inset: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 80% 60% at 10% 50%, rgba(0,180,255,.13) 0%, transparent 60%),
        radial-gradient(ellipse 60% 80% at 90% 20%, rgba(16,185,129,.10) 0%, transparent 50%);
    }
    .mj-hero-grid {
      position: absolute; inset: 0; pointer-events: none; opacity: .06;
      background-image:
        linear-gradient(rgba(255,255,255,.5) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.5) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    .mj-hero-inner { max-width: 900px; margin: 0 auto; position: relative; }

    .mj-breadcrumb {
      display: flex; gap: .45rem; align-items: center; flex-wrap: wrap;
      font-size: .75rem; color: #5a7899; margin-bottom: 1.5rem;
    }
    .mj-breadcrumb a { color: #5a7899; text-decoration: none; }
    .mj-breadcrumb a:hover { color: #93c5fd; }
    .mj-breadcrumb span { color: #2d4a66; }

    .mj-hero-text { margin-bottom: 2.5rem; }
    .mj-hero-tag {
      display: inline-flex; align-items: center; gap: .35rem;
      background: rgba(0,180,255,.15); border: 1px solid rgba(0,180,255,.3);
      color: #38bdf8; font-size: .72rem; font-weight: 600;
      letter-spacing: .08em; text-transform: uppercase;
      padding: .3rem .75rem; border-radius: 999px; margin-bottom: 1rem;
    }
    .mj-h1 {
      font-family: 'Sora', system-ui, sans-serif;
      font-size: clamp(2.5rem, 7vw, 4.5rem);
      font-weight: 800; line-height: 1.0;
      color: #f8fafc; margin: 0 0 .75rem;
      letter-spacing: -.02em;
    }
    .mj-h1-accent {
      background: linear-gradient(90deg, #38bdf8, #34d399);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .mj-subtitle {
      font-size: 1.05rem; color: #6b8cad; font-weight: 400; margin: 0;
    }

    /* ─── KPI row ───────────────────────────────── */
    .mj-kpi-row {
      display: flex; flex-wrap: wrap; gap: 0;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 16px; overflow: hidden;
      backdrop-filter: blur(8px);
    }
    .mj-kpi {
      flex: 1; min-width: 120px;
      display: flex; flex-direction: column; align-items: center;
      padding: 1.25rem 1rem; gap: .3rem;
      transition: background .2s;
    }
    .mj-kpi:hover { background: rgba(255,255,255,.06); }
    .mj-kpi-divider {
      width: 1px; background: rgba(255,255,255,.07);
      align-self: stretch; flex-shrink: 0;
    }
    .mj-kpi-icon { font-size: 1.25rem; margin-bottom: .1rem; }
    .mj-kpi-val {
      font-family: 'DM Mono', monospace;
      font-size: 1.35rem; font-weight: 500;
      color: #f0f9ff; line-height: 1.1;
    }
    .mj-kpi-lbl { font-size: .7rem; color: #5a7899; text-align: center; }

    /* ─── Content ───────────────────────────────── */
    .mj-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.25rem 5rem; }

    /* ─── Card ──────────────────────────────────── */
    .mj-card {
      background: #ffffff;
      border-radius: 24px;
      box-shadow:
        0 1px 0 0 rgba(0,0,0,.06),
        0 4px 6px -1px rgba(0,0,0,.05),
        0 24px 48px -8px rgba(0,0,0,.12);
      padding: 2rem 2rem 1.75rem;
      margin-bottom: 1.5rem;
      border: 1px solid rgba(0,0,0,.06);
    }
    .mj-card-label {
