      AG:{single:[{bis:3000,rate:0.063},{bis:5000,rate:0.110},{bis:8000,rate:0.149},{bis:12000,rate:0.193},{bis:999999,rate:0.234}],married:[{bis:4000,rate:0.027},{bis:6000,rate:0.063},{bis:10000,rate:0.108},{bis:15000,rate:0.146},{bis:999999,rate:0.181}]},
      TG:{single:[{bis:3000,rate:0.061},{bis:5000,rate:0.107},{bis:8000,rate:0.145},{bis:12000,rate:0.188},{bis:999999,rate:0.228}],married:[{bis:4000,rate:0.027},{bis:6000,rate:0.061},{bis:10000,rate:0.105},{bis:15000,rate:0.142},{bis:999999,rate:0.175}]},
      TI:{single:[{bis:3000,rate:0.088},{bis:5000,rate:0.154},{bis:8000,rate:0.209},{bis:12000,rate:0.270},{bis:999999,rate:0.326}],married:[{bis:4000,rate:0.038},{bis:6000,rate:0.088},{bis:10000,rate:0.152},{bis:15000,rate:0.205},{bis:999999,rate:0.253}]},
      VD:{single:[{bis:3000,rate:0.091},{bis:5000,rate:0.159},{bis:8000,rate:0.216},{bis:12000,rate:0.279},{bis:999999,rate:0.337}],married:[{bis:4000,rate:0.040},{bis:6000,rate:0.091},{bis:10000,rate:0.157},{bis:15000,rate:0.212},{bis:999999,rate:0.261}]},
      VS:{single:[{bis:3000,rate:0.075},{bis:5000,rate:0.132},{bis:8000,rate:0.179},{bis:12000,rate:0.232},{bis:999999,rate:0.281}],married:[{bis:4000,rate:0.033},{bis:6000,rate:0.075},{bis:10000,rate:0.130},{bis:15000,rate:0.175},{bis:999999,rate:0.216}]},
      NE:{single:[{bis:3000,rate:0.094},{bis:5000,rate:0.164},{bis:8000,rate:0.223},{bis:12000,rate:0.288},{bis:999999,rate:0.348}],married:[{bis:4000,rate:0.041},{bis:6000,rate:0.094},{bis:10000,rate:0.162},{bis:15000,rate:0.219},{bis:999999,rate:0.270}]},
      GE:{single:[{bis:3000,rate:0.109},{bis:5000,rate:0.191},{bis:8000,rate:0.259},{bis:12000,rate:0.335},{bis:999999,rate:0.404}],married:[{bis:4000,rate:0.047},{bis:6000,rate:0.109},{bis:10000,rate:0.188},{bis:15000,rate:0.254},{bis:999999,rate:0.313}]},
      JU:{single:[{bis:3000,rate:0.087},{bis:5000,rate:0.152},{bis:8000,rate:0.206},{bis:12000,rate:0.266},{bis:999999,rate:0.322}],married:[{bis:4000,rate:0.038},{bis:6000,rate:0.087},{bis:10000,rate:0.149},{bis:15000,rate:0.201},{bis:999999,rate:0.248}]},
    } as Record<string,{single:{bis:number,rate:number}[],married:{bis:number,rate:number}[]}>;
    const KANTON_NAMES: Record<string,string> = {ZH:'Zürich',BE:'Bern',LU:'Luzern',UR:'Uri',SZ:'Schwyz',OW:'Obwalden',NW:'Nidwalden',GL:'Glarus',ZG:'Zug',FR:'Freiburg',SO:'Solothurn',BS:'Basel-Stadt',BL:'Basel-Landschaft',SH:'Schaffhausen',AR:'Appenzell A.Rh.',AI:'Appenzell I.Rh.',SG:'St. Gallen',GR:'Graubünden',AG:'Aargau',TG:'Thurgau',TI:'Tessin',VD:'Waadt',VS:'Wallis',NE:'Neuenburg',GE:'Genf',JU:'Jura'};
    function getRate(kz: string, brutto: number, tarif: 'single'|'married'): number {
      const t = KANTONE_DATA[kz]?.[tarif];
      if (!t) return 0;
      const found = t.find(b => brutto <= b.bis);
      return found ? found.rate : t[t.length-1].rate;
    }
    function fmtCHF(n: number) { return n.toLocaleString('de-CH', {maximumFractionDigits:0}) + ' CHF'; }
    function fmtPct(r: number) { return (r*100).toFixed(1).replace('.',',') + ' %'; }
    // Build comparison table on load
    function buildTable(brutto=7000) {
      const tbody = document.getElementById('qst-tbody')!;
      const rows = Object.entries(KANTONE_DATA).map(([kz]) => {
        const r = getRate(kz, brutto, 'single');
        return {kz, name:KANTON_NAMES[kz], rate:r, qst:Math.round(brutto*r)};
      }).sort((a,b) => a.rate - b.rate);
      tbody.innerHTML = rows.map((r, i) => {
        const color = r.rate < 0.09 ? 'text-green-700' : r.rate < 0.17 ? 'text-orange-600' : 'text-red-600';
        return `<tr class="hover:bg-gray-50 ${i===0?'bg-green-50':''}">
          <td class="px-3 py-2 border font-medium text-gray-800">${r.name} (${r.kz})</td>
          <td class="text-center px-3 py-2 border ${color} font-bold">${fmtPct(r.rate)}</td>
          <td class="text-center px-3 py-2 border text-gray-600">${fmtCHF(r.qst)}</td>
          <td class="text-center px-3 py-2 border text-gray-600">${fmtCHF(brutto - r.qst)}</td>
        </tr>`;
      }).join('');
    }
    buildTable();
    (window as any).calcQST = function() {
      const kz = (document.getElementById('qst-kanton') as HTMLSelectElement).value;
      const brutto = parseFloat((document.getElementById('qst-brutto') as HTMLInputElement).value) || 0;
      const tarif = (document.getElementById('qst-tarif') as HTMLSelectElement).value as 'single'|'married';
      const kinder = parseInt((document.getElementById('qst-kinder') as HTMLSelectElement).value) || 0;
      let rate = getRate(kz, brutto, tarif);
      // Kinderabzug: grob -1.5% pro Kind
      rate = Math.max(0, rate - kinder * 0.015);
      const qst = Math.round(brutto * rate);
      const netto = brutto - qst;
      const r = document.getElementById('qst-result')!; r.classList.remove('hidden');
      document.getElementById('qst-betrag')!.textContent = fmtCHF(qst);
      document.getElementById('qst-rate')!.textContent = fmtPct(rate);
      document.getElementById('qst-netto')!.textContent = fmtCHF(netto);
      document.getElementById('qst-year')!.textContent = fmtCHF(qst * 12);
      buildTable(brutto);
    };
  </script>
  <Footer slot="footer" />
</BaseLayout>
